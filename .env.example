# Bu dosyayı kopyalayıp ".env" olarak kaydet, sonra değerleri doldur.
# .env dosyasını ASLA GitHub'a yükleme!
#
# Kullanım: cp .env.example .env

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=guclu_bir_sifre_sec

# ─── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=buraya_gemini_api_keyini_yaz

# ─── CORS: İzin verilen frontend URL'leri (virgülle ayır) ─────────────────────
# Yerel test: http://localhost:5173
# Production: https://anlasamiyoruz.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Render / Railway / Fly.io: PORT (opsiyonel) ──────────────────────────────
# Bu platformlar PORT'u otomatik atar; docker-compose için genelde gerekmez.
# PORT=8080
