# Bu dosyayı kopyalayıp ".env" olarak kaydet, sonra değerleri doldur.
# .env dosyasını ASLA GitHub'a yükleme!

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=guclu_bir_sifre_sec

# ─── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY=buraya_gemini_api_keyini_yaz

# ─── CORS: Frontend production URL'leri (virgülle ayır) ───────────────────────
# Örnek: https://anlasamiyoruz.vercel.app,https://www.anlasamiyoruz.com
CORS_ALLOWED_ORIGINS=http://localhost

# ─── Frontend API URL (Docker build sırasında kullanılır) ─────────────────────
# Örnek: https://api.anlasamiyoruz.com
VITE_API_URL=http://localhost:8080
